{
  "name": "mcp-ansc-server",
  "version": "1.0.1",
  "description": "MCP server for Moldova's National Agency for Solving Complaints (ANSC) — appeals, decisions, hearing schedule, and multi-modal PDF extraction.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-ansc-server": "build/index.js"
  },
  "types": "build/index.d.ts",
  "homepage": "https://github.com/nalyk/ansc-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nalyk/ansc-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/nalyk/ansc-mcp-server/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "build",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc && node -e \"import('node:fs').then(m=>m.default.chmodSync('build/index.js','755'))\"",
    "start": "node build/index.js",
    "start:http": "MCP_TRANSPORT=http node build/index.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "tsc --noEmit",
    "inspect": "npx --yes @modelcontextprotocol/inspector node build/index.js",
    "clean": "rm -rf build coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ansc",
    "moldova",
    "public-procurement",
    "appeals"
  ],
  "author": "Ion Nalyk Calmis",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.0",
    "jose": "^6.2.0",
    "lru-cache": "^11.3.0",
    "pino": "^10.3.0",
    "sharp": "^0.34.5",
    "undici": "^8.1.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.8.0"
  }
}
