# --- Transport ---
# stdio (local subprocess) | http (Streamable HTTP for remote)
MCP_TRANSPORT=stdio

# --- HTTP transport (only used when MCP_TRANSPORT=http) ---
HTTP_HOST=127.0.0.1
HTTP_PORT=3030
# Public URL of this MCP server. Required when AUTH_MODE=oauth — must match the
# `aud` claim of valid tokens (RFC 8707).
HTTP_PUBLIC_URL=http://127.0.0.1:3030

# --- Authentication (only used when MCP_TRANSPORT=http) ---
# none  → no auth (dev only; do not expose publicly)
# oauth → OAuth 2.1 Resource Server profile (RFC 9728 + RFC 8707)
AUTH_MODE=none

# Required when AUTH_MODE=oauth
# OAuth 2.1 Authorization Server issuer URL (used to discover JWKS).
OAUTH_ISSUER=
# Optional: override JWKS URL if AS does not publish .well-known/openid-configuration.
OAUTH_JWKS_URL=
# Required scopes (space-separated) the bearer token must contain. Empty = no scope check.
OAUTH_REQUIRED_SCOPES=

# --- Scraping ---
# 30s default. Increase only if ANSC is having a bad day.
ANSC_HTTP_TIMEOUT_MS=30000
# Bypass TLS validation only for these hostnames (comma-separated).
# ANSC currently ships an invalid cert; this is a targeted workaround.
ANSC_TLS_BYPASS_HOSTS=www.ansc.md,elo.ansc.md
# Modern user-agent. Override if ANSC ever blocks a string.
ANSC_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36

# --- Cache ---
# HTML cache TTL in seconds for the *current* year (active data).
CACHE_TTL_CURRENT_S=300
# HTML cache TTL in seconds for *historical* years (rarely changes).
CACHE_TTL_HISTORICAL_S=86400
CACHE_MAX_ENTRIES=500

# --- Logging ---
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
